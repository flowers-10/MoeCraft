# Copy to deploy/staging.env and replace every placeholder locally or in the secret manager.
API_IMAGE=ghcr.io/<organization>/moecraft-api@sha256:<immutable-image-digest>
API_HOST_PORT=3102
PORT=3102
SERVICE_ENVIRONMENT=staging
CORS_ORIGINS=https://staging-storefront.example.com,https://staging-admin.example.com
DATABASE_URL=mysql://<app-user>:<app-password>@database:3306/moecraft
JWT_ACCESS_SECRET=<generate-at-least-32-random-characters>
JWT_ACCESS_EXPIRES_IN=15m
TELEMETRY_EXPORT_URL=https://telemetry-staging.example.com/events
TELEMETRY_EXPORT_TOKEN=<staging-only-token>
MYSQL_DATABASE=moecraft
MYSQL_USER=<app-user>
MYSQL_PASSWORD=<app-password>
MYSQL_ROOT_PASSWORD=<root-password>
