DATABASE_URL="mysql://root:<replace-with-local-password>@127.0.0.1:3306/moecraft"
JWT_ACCESS_SECRET="<generate-at-least-32-random-characters>"
JWT_ACCESS_EXPIRES_IN="8h"
PORT="3002"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
# Optional and used only by `pnpm --filter @moecraft/api db:seed`.
SEED_ADMIN_PASSWORD="<set-a-strong-local-password-before-seeding>"
