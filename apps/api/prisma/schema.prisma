generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum MerchantStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum FileStatus {
  PENDING
  READY
  QUARANTINED
  DELETED
}

enum MerchantApplicationStatus {
  DRAFT
  SUBMITTED
  NEEDS_CHANGES
  APPROVED
  REJECTED
  WITHDRAWN
}

enum MerchantMemberRole {
  OWNER
  STAFF
}

enum StaffInvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

model FileAsset {
  id          String     @id @default(cuid())
  ownerId     String
  purpose     String     @db.VarChar(80)
  objectKey   String     @unique @db.VarChar(255)
  fileName    String     @db.VarChar(255)
  mimeType    String     @db.VarChar(120)
  sizeBytes   Int
  status      FileStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([ownerId, purpose, status])
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique @db.VarChar(80)
  displayName  String     @db.VarChar(120)
  passwordHash String     @db.VarChar(255)
  isActive     Boolean    @default(true)
  roles        UserRole[]
  sessions     Session[]
  resetTokens  PasswordResetToken[]
  merchantApplications MerchantApplication[] @relation("MerchantApplicant")
  reviewedMerchantApplications MerchantApplication[] @relation("MerchantReviewer")
  applicationTimeline MerchantApplicationTimeline[]
  ownedMerchant Merchant? @relation("MerchantOwner")
  merchantMemberships MerchantMember[]
  receivedStaffInvitations StaffInvitation[] @relation("StaffInvitee")
  sentStaffInvitations StaffInvitation[] @relation("StaffInviter")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @db.VarChar(255)
  expiresAt        DateTime
  revokedAt        DateTime?
  userAgent        String?   @db.VarChar(255)
  ipAddress        String?   @db.VarChar(64)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique @db.Char(64)
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String   @db.VarChar(100)
  targetType String?  @db.VarChar(80)
  targetId   String?  @db.VarChar(191)
  ipAddress  String?  @db.VarChar(64)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      String   @db.VarChar(50)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
}

model Merchant {
  id        String         @id @default(cuid())
  ownerId   String?        @unique
  name      String         @db.VarChar(160)
  status    MerchantStatus @default(ACTIVE)
  store     Store?
  owner     User?          @relation("MerchantOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members   MerchantMember[]
  staffInvitations StaffInvitation[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model MerchantMember {
  id         String             @id @default(cuid())
  merchantId String
  userId     String
  role       MerchantMemberRole @default(STAFF)
  routePermissions Json?
  buttonPermissions Json?
  merchant   Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([merchantId, userId])
  @@index([userId])
}

model StaffInvitation {
  id         String                @id @default(cuid())
  merchantId String
  inviteeId  String
  invitedById String
  role       MerchantMemberRole    @default(STAFF)
  status     StaffInvitationStatus @default(PENDING)
  expiresAt  DateTime
  merchant   Merchant              @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  invitee    User                  @relation("StaffInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  invitedBy  User                  @relation("StaffInviter", fields: [invitedById], references: [id], onDelete: Restrict)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([inviteeId, status, expiresAt])
  @@index([merchantId, status])
}

model MerchantApplication {
  id                    String                    @id @default(cuid())
  applicantId           String
  reviewerId            String?
  status                MerchantApplicationStatus @default(DRAFT)
  companyName           String                    @db.VarChar(160)
  contactName           String                    @db.VarChar(120)
  contactPhone          String                    @db.VarChar(40)
  contactEmail          String                    @db.VarChar(160)
  businessLicenseNumber String                    @db.VarChar(100)
  qualificationFileIds  Json
  agreementAccepted     Boolean                   @default(false)
  reviewComment         String?                   @db.VarChar(1000)
  submittedAt           DateTime?
  reviewedAt            DateTime?
  applicant             User                      @relation("MerchantApplicant", fields: [applicantId], references: [id], onDelete: Restrict)
  reviewer              User?                     @relation("MerchantReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)
  timeline              MerchantApplicationTimeline[]
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([applicantId, createdAt])
  @@index([status, submittedAt])
}

model MerchantApplicationTimeline {
  id            String                    @id @default(cuid())
  applicationId String
  actorId       String
  fromStatus    MerchantApplicationStatus?
  toStatus      MerchantApplicationStatus
  comment       String?                   @db.VarChar(1000)
  application   MerchantApplication       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actor         User                      @relation(fields: [actorId], references: [id], onDelete: Restrict)
  createdAt     DateTime                  @default(now())

  @@index([applicationId, createdAt])
}

model Store {
  id         String    @id @default(cuid())
  merchantId String    @unique
  name       String    @db.VarChar(160)
  slug       String    @unique @db.VarChar(120)
  isOpen     Boolean   @default(true)
  logoFileId String?
  bannerFileId String?
  description String?  @db.Text
  customerServiceEmail String? @db.VarChar(160)
  customerServicePhone String? @db.VarChar(40)
  returnAddress Json?
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Category {
  id                 String              @id @default(cuid())
  parentId           String?
  slug               String              @unique @db.VarChar(120)
  nameZhCn           String              @db.VarChar(160)
  nameEnUs           String?             @db.VarChar(160)
  descriptionZhCn    String?             @db.VarChar(500)
  descriptionEnUs    String?             @db.VarChar(500)
  isActive           Boolean             @default(true)
  sortOrder          Int                 @default(0)
  parent             Category?           @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children           Category[]          @relation("CategoryTree")
  products           Product[]
  attributeTemplates AttributeTemplate[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([parentId, sortOrder])
  @@index([isActive, sortOrder])
}

model Brand {
  id          String    @id @default(cuid())
  slug        String    @unique @db.VarChar(120)
  nameZhCn    String    @db.VarChar(160)
  nameEnUs    String?   @db.VarChar(160)
  descriptionZhCn String? @db.VarChar(500)
  descriptionEnUs String? @db.VarChar(500)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, sortOrder])
}

model Franchise {
  id          String      @id @default(cuid())
  slug        String      @unique @db.VarChar(120)
  nameZhCn    String      @db.VarChar(160)
  nameEnUs    String?     @db.VarChar(160)
  descriptionZhCn String? @db.VarChar(500)
  descriptionEnUs String? @db.VarChar(500)
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  characters Character[]
  products    Product[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([isActive, sortOrder])
}

model Character {
  id          String    @id @default(cuid())
  franchiseId String
  slug        String    @unique @db.VarChar(120)
  nameZhCn    String    @db.VarChar(160)
  nameEnUs    String?   @db.VarChar(160)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Restrict)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([franchiseId, isActive, sortOrder])
}

model Tag {
  id        String    @id @default(cuid())
  slug      String    @unique @db.VarChar(120)
  nameZhCn  String    @db.VarChar(100)
  nameEnUs  String?   @db.VarChar(100)
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive, sortOrder])
}

model AttributeTemplate {
  id          String     @id @default(cuid())
  categoryId  String?
  code        String     @unique @db.VarChar(80)
  nameZhCn    String     @db.VarChar(120)
  nameEnUs    String?    @db.VarChar(120)
  inputType   String     @db.VarChar(30)
  options     Json?
  isRequired  Boolean    @default(false)
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  category    Category?  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([categoryId, isActive, sortOrder])
}

model Product {
  id         String        @id @default(cuid())
  storeId    String
  categoryId String
  brandId    String?
  franchiseId String?
  characterId String?
  titleZhCn  String        @db.VarChar(200)
  titleEnUs  String?       @db.VarChar(200)
  status     ProductStatus @default(DRAFT)
  store      Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  category   Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand      Brand?        @relation(fields: [brandId], references: [id], onDelete: Restrict)
  franchise  Franchise?    @relation(fields: [franchiseId], references: [id], onDelete: Restrict)
  character  Character?    @relation(fields: [characterId], references: [id], onDelete: Restrict)
  tags       Tag[]
  skus       Sku[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([storeId, status])
  @@index([categoryId, status])
  @@index([brandId, status])
  @@index([franchiseId, status])
  @@index([characterId, status])
}

model Sku {
  id          String     @id @default(cuid())
  productId   String
  code        String     @unique @db.VarChar(80)
  nameZhCn    String     @db.VarChar(160)
  nameEnUs    String?    @db.VarChar(160)
  priceAmount Int
  currency    String     @default("CNY") @db.Char(3)
  product     Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventory   Inventory?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([productId])
}

model Inventory {
  id        String   @id @default(cuid())
  skuId     String   @unique
  onHand    Int      @default(0)
  reserved  Int      @default(0)
  sku       Sku      @relation(fields: [skuId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
